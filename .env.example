# Twitter / X Credentials
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password
TWITTER_AUTH_TOKEN=xxx
TWITTER_CT0=xxxx

# Anthropic API (primary — leave empty to use Gemini instead)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Gemini API (fallback — get from https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# Openrouter API
OPENROUTER_API_KEY=sk-or-v1-XXXxxxx

# Database
DATABASE_URL=postgresql+asyncpg://pipeline_user:pipeline_pass@db:5432/content_pipeline

# Redis
REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=change-me-to-a-random-secret
ENVIRONMENT=development

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000
